{
  "name": "gh-workflow-explorer",
  "exports": "./src/main.ts",
  "tasks": {
    "dev": "deno run --allow-run=gh --allow-env src/main.ts",
    "test": "deno test --allow-read=tests/fixtures",
    "check": "deno check src/main.ts tests/**/*.ts",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "compile": "deno compile --allow-run=gh --allow-env=NO_COLOR,HOME,PATH --output dist/gh-workflow-explorer src/main.ts"
  },
  "imports": {
    "@std/cli/parse-args": "jsr:@std/cli@^1/parse-args",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/fmt/colors": "jsr:@std/fmt@^1/colors",
    "@std/async/pool": "jsr:@std/async@^1/pool"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true
  }
}
